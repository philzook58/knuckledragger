(declare-sort Kleene 0)
(declare-fun par1 (Kleene Kleene) Kleene)
(declare-fun _0 () Kleene)
(declare-fun seq (Kleene Kleene) Kleene)
(declare-fun _1 () Kleene)
(declare-fun star (Kleene) Kleene)
(declare-fun x () Kleene)
(assert (forall ((x Kleene) (y Kleene) (z Kleene))
  (= (par1 x (par1 y z)) (par1 (par1 x y) z))))
(assert (forall ((x Kleene) (y Kleene)) (= (par1 x y) (par1 y x))))
(assert (forall ((x Kleene)) (= (par1 x x) x)))
(assert (forall ((x Kleene)) (= (par1 x _0) x)))
(assert (forall ((x Kleene) (y Kleene) (z Kleene))
  (= (seq x (seq y z)) (seq (seq x y) z))))
(assert (forall ((x Kleene)) (= (seq x _0) _0)))
(assert (forall ((x Kleene)) (= (seq x _1) x)))
(assert (forall ((x Kleene) (y Kleene) (z Kleene))
  (= (seq x (par1 y z)) (par1 (seq x y) (seq x z)))))
(assert (forall ((x Kleene) (y Kleene) (z Kleene))
  (= (seq (par1 y z) x) (par1 (seq y x) (seq z x)))))
(assert (forall ((e Kleene)) (= (star e) (par1 _1 (seq e (star e))))))
(assert (forall ((x Kleene) (e Kleene) (f Kleene))
  (let ((a!1 (= (par1 (par1 f (seq e x)) x) x))
        (a!2 (= (par1 (seq (star e) f) x) x)))
    (=> a!1 a!2))))
(assert (not (= (star (star x)) (star x))))
(check-sat)